{
  "permissions": {
    "allow": [
      "Bash(git:*)",
      "Bash(gh:*)",
      "Bash(make:*)",
      "Bash(pre-commit:*)",
      "Bash(ruff:*)",
      "Bash(spfm:*)",
      "Bash(time uv run:*)",
      "Bash(uv:*)",
      "Bash(rm -rf .pytest_cache:*)",
      "Bash(rm -rf .ruff_cache:*)",
      "Bash(rm -rf __pycache__:*)",
      "Bash(rm -rf build:*)",
      "Bash(rm -rf dist:*)",
      "Bash(rm -rf *.egg-info:*)",
      "Skill(create-pr:*)",
      "Skill(review-pr)"
    ],
    "deny": [
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)",
      "Bash(rm -rf /*:*)",
      "Bash(rm -rf ~:*)",
      "Bash(rm -rf .:*)"
    ]
  }
}
